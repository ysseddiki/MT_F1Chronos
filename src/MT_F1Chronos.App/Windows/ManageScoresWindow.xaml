<Window x:Class="MT_F1Chronos.App.Windows.ManageScoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gérer les chronos"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="520"
        Height="640"
        ShowInTaskbar="False">
    <Border CornerRadius="8"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F50D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <Grid Grid.Column="1" Margin="14,14,14,14">
                <Grid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#FF161B22"/>
                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1C222B"/>
                                <Setter Property="BorderBrush" Value="#88E10600"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0D1117"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#44FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="DangerButton" TargetType="Button">
                        <Setter Property="Background" Value="#FF161B22"/>
                        <Setter Property="Foreground" Value="#FFFF8A80"/>
                        <Setter Property="BorderBrush" Value="#66E10600"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1C222B"/>
                                <Setter Property="BorderBrush" Value="#88E10600"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0D1117"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#44FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,12" Cursor="SizeAll" MouseLeftButtonDown="OnHeaderDrag">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="GÉRER LES CHRONOS"
                                   FontFamily="Segoe UI"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Suppression ciblée · circuit · concours · reset"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="✕"
                            Width="28"
                            Height="28"
                            Padding="0"
                            FontSize="14"
                            Click="OnCloseClick"/>
                </Grid>

                <!-- Source + track -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tableau"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,4"/>
                        <ComboBox x:Name="SourceCombo"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="OnSourceChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <TextBlock Text="Circuit"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,4"
                                   HorizontalAlignment="Center"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PrevTrackButton"
                                    Grid.Column="0"
                                    Content="◀"
                                    Width="32"
                                    Height="34"
                                    Padding="0"
                                    Click="OnPrevTrackClick"/>
                            <TextBlock x:Name="TrackTitleText"
                                       Grid.Column="1"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="6,0"/>
                            <Button x:Name="NextTrackButton"
                                    Grid.Column="2"
                                    Content="▶"
                                    Width="32"
                                    Height="34"
                                    Padding="0"
                                    Click="OnNextTrackClick"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Filters -->
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Joueur"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,4"/>
                        <ComboBox x:Name="PlayerCombo"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="OnPlayerFilterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <TextBlock Text="Vue"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,4"
                                   HorizontalAlignment="Center"/>
                        <Button x:Name="BestPerPlayerButton"
                                Content="Tous"
                                Width="100"
                                Height="34"
                                Click="OnBestPerPlayerClick"/>
                    </StackPanel>
                </Grid>

                <!-- Context actions -->
                <StackPanel Grid.Row="3" Margin="0,0,0,10">
                    <TextBlock Text="ACTIONS SUR CE CIRCUIT"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="DeletePlayerButton"
                                Grid.Column="0"
                                Content="Supprimer le joueur…"
                                Style="{StaticResource DangerButton}"
                                Click="OnDeletePlayerClick"/>
                        <Button x:Name="ClearTrackButton"
                                Grid.Column="2"
                                Content="Effacer ce circuit…"
                                Style="{StaticResource DangerButton}"
                                Click="OnClearTrackClick"/>
                    </Grid>
                    <TextBlock x:Name="ContextHintText"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Foreground="#FFC5CAD3"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- List -->
                <Border Grid.Row="4"
                        Background="#FF0D1117"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ListHintText"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,6"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ScoresPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Board-wide danger -->
                <StackPanel Grid.Row="5" Margin="0,12,0,0">
                    <TextBlock Text="ZONE DANGEREUSE"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,6"/>
                    <Button x:Name="ClearBoardButton"
                            Content="Vider entièrement ce tableau…"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,0,6"
                            Click="OnClearBoardClick"/>
                    <Button Content="Réinitialisation complète (global + tous les concours)…"
                            Style="{StaticResource DangerButton}"
                            Click="OnFullResetClick"/>
                </StackPanel>

                <Button Grid.Row="6"
                        Content="Fermer"
                        Width="90"
                        Height="32"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Right"
                        Click="OnCloseClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
