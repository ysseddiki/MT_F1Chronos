<Window x:Class="MT_F1Chronos.App.Windows.ScoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scores par circuit"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="400"
        Height="580"
        ShowInTaskbar="False">
    <Border CornerRadius="8"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F50D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- F1 accent bar -->
            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <Grid Grid.Column="1" Margin="14,14,14,14">
                <Grid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#FF161B22"/>
                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1C222B"/>
                                <Setter Property="BorderBrush" Value="#88E10600"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0D1117"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#44FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,10"
                      Cursor="SizeAll"
                      MouseLeftButtonDown="OnHeaderDrag">
                    <TextBlock x:Name="WindowTitleText"
                               Text="Scores par circuit"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"/>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Source"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Foreground="#FFC5CAD3"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="SourceCombo"
                              FontFamily="Segoe UI"
                              FontSize="13"
                              Height="34"
                              Padding="8,4"
                              Background="#FF161B22"
                              Foreground="White"
                              BorderBrush="#33FFFFFF"
                              BorderThickness="1"
                              SelectionChanged="OnSourceChanged">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF161B22"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF1C222B"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF161B22"/>
                        </ComboBox.Resources>
                        <ComboBox.Template>
                            <ControlTemplate TargetType="ComboBox">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Chrome"
                                                        Background="#FF161B22"
                                                        BorderBrush="#33FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0"
                                                                          Margin="8,0,4,0"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"
                                                                          Content="{TemplateBinding Content}"
                                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                          RecognizesAccessKey="True"/>
                                                        <Path Grid.Column="1"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Data="M 0 0 L 6 6 L 12 0 Z"
                                                              Fill="#FFC5CAD3"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite"
                                                      IsHitTestVisible="False"
                                                      Margin="10,0,32,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                                    <Popup x:Name="Popup"
                                           Placement="Bottom"
                                           IsOpen="{TemplateBinding IsDropDownOpen}"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border x:Name="DropDown"
                                                MinWidth="{TemplateBinding ActualWidth}"
                                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                Background="#FF161B22"
                                                BorderBrush="#33FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Margin="0,2,0,0">
                                            <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </ControlTemplate>
                        </ComboBox.Template>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#FF161B22"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF1C222B"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF1C222B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Joueur"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,4"/>
                        <ComboBox x:Name="PlayerCombo"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  Height="34"
                                  Padding="8,4"
                                  Background="#FF161B22"
                                  Foreground="White"
                                  BorderBrush="#33FFFFFF"
                                  SelectionChanged="OnPlayerFilterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <TextBlock Text="Meilleur / joueur"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   Margin="0,0,0,4"
                                   HorizontalAlignment="Center"/>
                        <Button x:Name="BestPerPlayerButton"
                                      Content="Tous"
                                      Width="88"
                                      Height="34"
                                      FontSize="12"
                                      Click="OnBestPerPlayerClick"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PrevTrackButton"
                            Grid.Column="0"
                            Content="◀"
                            Width="32"
                            Height="28"
                            FontSize="12"
                            Click="OnPrevTrackClick"/>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="8,0">
                        <TextBlock x:Name="TrackTitleText"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TrackIndexText"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Foreground="#FFC5CAD3"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Button x:Name="NextTrackButton"
                            Grid.Column="2"
                            Content="▶"
                            Width="32"
                            Height="28"
                            FontSize="12"
                            Click="OnNextTrackClick"/>
                </Grid>

                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ScoresPanel"/>
                </ScrollViewer>

                <Button Grid.Row="5"
                        Content="Fermer"
                        Width="90"
                        Height="32"
                        FontSize="12"
                        Margin="0,14,0,0"
                        HorizontalAlignment="Right"
                        Click="OnCloseClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
