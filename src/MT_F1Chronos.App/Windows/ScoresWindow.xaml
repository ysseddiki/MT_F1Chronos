<Window x:Class="MT_F1Chronos.App.Windows.ScoresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scores par circuit"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="400"
        Height="480"
        ShowInTaskbar="False">
    <Border CornerRadius="6"
            BorderThickness="1"
            Padding="16">
        <Border.Background>
            <SolidColorBrush Color="#F0101018"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#FFE10600"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Scores par circuit"
                       FontFamily="Segoe UI"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,12"/>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevTrackButton"
                        Grid.Column="0"
                        Content="◀"
                        Width="32"
                        Height="28"
                        FontSize="12"
                        Click="OnPrevTrackClick"
                        Background="#FF2A2A34"
                        Foreground="White"
                        BorderBrush="#44FFFFFF"/>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="8,0">
                    <TextBlock x:Name="TrackTitleText"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TrackIndexText"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Foreground="#88FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button x:Name="NextTrackButton"
                        Grid.Column="2"
                        Content="▶"
                        Width="32"
                        Height="28"
                        FontSize="12"
                        Click="OnNextTrackClick"
                        Background="#FF2A2A34"
                        Foreground="White"
                        BorderBrush="#44FFFFFF"/>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ScoresPanel"/>
            </ScrollViewer>

            <Button Grid.Row="3"
                    Content="Fermer"
                    Width="90"
                    Height="32"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Right"
                    Click="OnCloseClick"
                    Background="#FF2A2A34"
                    Foreground="White"
                    BorderBrush="#44FFFFFF"/>
        </Grid>
    </Border>
</Window>
