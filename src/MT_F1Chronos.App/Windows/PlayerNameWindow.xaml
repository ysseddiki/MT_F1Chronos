<Window x:Class="MT_F1Chronos.App.Windows.PlayerNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nom du joueur"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="340"
        SizeToContent="Height"
        ShowInTaskbar="False">
    <Border CornerRadius="8"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F50D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.Resources>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#FF161B22"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="#88E10600"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- F1 accent bar -->
            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <StackPanel Grid.Column="1" Margin="14,16,14,16">
                <TextBlock Text="Bienvenue sur MT_F1Chronos"
                           FontFamily="Segoe UI"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Choisis ton nom de joueur. Il sera utilisé pour tous tes chronos."
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFC5CAD3"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Nom du joueur"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFC5CAD3"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox"
                         FontFamily="Segoe UI"
                         FontSize="14"
                         Padding="8,6"
                         Background="#FF161B22"
                         Foreground="White"
                         BorderBrush="#33FFFFFF"
                         CaretBrush="#FFE10600"
                         Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Valider"
                            Width="90"
                            Height="32"
                            FontFamily="Segoe UI"
                            Click="OnConfirmClick"
                            Background="#FFE10600"
                            Foreground="White"
                            BorderBrush="#FFE10600"
                            Cursor="Hand"
                            IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
