<Window x:Class="MT_F1Chronos.App.Windows.SetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mot de passe admin"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="360"
        SizeToContent="Height"
        ShowInTaskbar="False">
    <Border CornerRadius="8"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F50D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <StackPanel Grid.Column="1" Margin="14,16,14,16">
                <TextBlock x:Name="TitleText"
                           FontFamily="Segoe UI"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="MessageText"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFC5CAD3"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Nouveau mot de passe"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFC5CAD3"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             Padding="8,6"
                             Background="#FF161B22"
                             Foreground="White"
                             BorderBrush="#33FFFFFF"
                             CaretBrush="#FFE10600"
                             Margin="0,0,0,10"/>

                <TextBlock Text="Confirmer"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFC5CAD3"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmBox"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             Padding="8,6"
                             Background="#FF161B22"
                             Foreground="White"
                             BorderBrush="#33FFFFFF"
                             CaretBrush="#FFE10600"
                             Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FFFF8A80"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Annuler"
                            Width="90"
                            Height="32"
                            Margin="0,0,8,0"
                            FontFamily="Segoe UI"
                            Background="#FF161B22"
                            Foreground="White"
                            BorderBrush="#33FFFFFF"
                            Cursor="Hand"
                            Click="OnCancelClick"
                            IsCancel="True"/>
                    <Button Content="Enregistrer"
                            Width="100"
                            Height="32"
                            FontFamily="Segoe UI"
                            Background="#FFE10600"
                            Foreground="White"
                            BorderBrush="#FFE10600"
                            Cursor="Hand"
                            Click="OnConfirmClick"
                            IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
