<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="F1 Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="4"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F015151E"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#33FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Soft white edge (mockup) -->
            <Border Grid.Column="0"
                    Background="#55FFFFFF"
                    CornerRadius="4,0,0,4"/>

            <StackPanel Grid.Column="1" Margin="12,12,12,10">
                <!-- Header: circuit + player · live chrono -->
                <Grid Margin="0,0,0,14" MouseLeftButtonDown="OnHeaderDrag">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock x:Name="TrackText"
                                   FontFamily="Bahnschrift, Segoe UI"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   FontStyle="Italic"
                                   FontStretch="Condensed"
                                   Foreground="#FFFFFFFF"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PlayerNameText"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFA8A8B3"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="CurrentLapText"
                               Grid.Column="1"
                               FontFamily="Consolas"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#FFFFFFFF"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- TOP Global cartouche -->
                <Border x:Name="GlobalSection"
                        Background="#FF1A1A24"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#FFE10600"
                                CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1">
                            <Border Background="#FF252530" Padding="8,8">
                                <TextBlock x:Name="LeaderboardTitleText"
                                           Text="TOP 5 · GLOBAL"
                                           FontFamily="Bahnschrift, Segoe UI"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           FontStretch="Condensed"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Height="1" Fill="#33FFFFFF"/>
                            <StackPanel x:Name="TopFivePanel" Margin="8,8,8,8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Separation -->
                <TextBlock x:Name="ContestDivider"
                           Text="···"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#55FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,10"
                           Visibility="Collapsed"/>

                <!-- TOP Concours cartouche -->
                <Border x:Name="ContestSection"
                        Background="#FF1A1A24"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="Collapsed"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#FF5E8BFF"
                                CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1">
                            <Border Background="#FF252530" Padding="8,8">
                                <TextBlock x:Name="ContestTitleText"
                                           Text="TOP 5 · CONCOURS"
                                           FontFamily="Bahnschrift, Segoe UI"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           FontStretch="Condensed"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Height="1" Fill="#33FFFFFF"/>
                            <StackPanel x:Name="ContestPanel" Margin="8,8,8,8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Footer: status LED + burger -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="StatusBadge"
                          Grid.Column="1"
                          Width="28"
                          Height="28"
                          ClipToBounds="False"
                          VerticalAlignment="Center"
                          Margin="0,0,2,0"
                          ToolTip="Télémétrie">
                        <Ellipse x:Name="StatusGlow"
                                 Width="14"
                                 Height="14"
                                 Fill="#FFE10600"
                                 Opacity="0.9"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <BlurEffect x:Name="StatusGlowBlur"
                                            Radius="12"
                                            KernelType="Gaussian"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Border x:Name="StatusRing"
                                Width="11"
                                Height="11"
                                CornerRadius="2.5"
                                BorderThickness="1.25"
                                BorderBrush="#FFE10600"
                                Background="#66000000"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"/>
                        <Border x:Name="StatusCore"
                                Width="5"
                                Height="5"
                                CornerRadius="1.5"
                                Background="#FFE10600"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                            <Border.Effect>
                                <DropShadowEffect x:Name="StatusCoreGlow"
                                                  BlurRadius="10"
                                                  ShadowDepth="0"
                                                  Color="#FFE10600"
                                                  Opacity="0.95"/>
                            </Border.Effect>
                        </Border>
                    </Grid>

                    <Button x:Name="MenuButton"
                            Grid.Column="2"
                            Content="☰"
                            Width="28"
                            Height="24"
                            FontSize="14"
                            Padding="0"
                            Background="Transparent"
                            Foreground="#FFFFFFFF"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="OnMenuButtonClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu Background="#FF1A1A24"
                                         Foreground="#FFFFFFFF"
                                         BorderBrush="#33FFFFFF"
                                         BorderThickness="1"
                                         Padding="4">
                                <ContextMenu.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFFFFFFF"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF252530"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>

                                    <Style TargetType="{x:Type ContextMenu}">
                                        <Setter Property="Background" Value="#FF1A1A24"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                    <Style TargetType="{x:Type MenuItem}">
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="Margin" Value="2,1"/>
                                        <Setter Property="Background" Value="#FF1A1A24"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#FF252530"/>
                                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type Separator}">
                                        <Setter Property="Margin" Value="6,6"/>
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                                <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                                <MenuItem Header="Administration" Click="OnAdminClick"/>
                                <Separator/>
                                <MenuItem Header="Quitter" Click="OnQuitClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
