<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT_F1Chronos Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="False"
        ShowActivated="False">
    <Border x:Name="RootBorder"
            CornerRadius="4"
            BorderThickness="1"
            Padding="10,8"
            Opacity="0.88">
        <Border.Background>
            <SolidColorBrush Color="#CC0A0A0F"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#55FFFFFF"/>
        </Border.BorderBrush>
        <StackPanel>
            <TextBlock x:Name="TrackText"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#FFB0B8C8"
                       Margin="0,0,0,6"/>

            <TextBlock Text="TOP 3"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#FFE10600"
                       Margin="0,0,0,4"/>

            <StackPanel x:Name="TopThreePanel" Margin="0,0,0,8"/>

            <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,8"/>

            <TextBlock Text="TON MEILLEUR"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#FF00D2BE"
                       Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SessionNameText"
                           Grid.Column="0"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="CurrentBestText"
                           Grid.Column="1"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FFFFD700"
                           Margin="12,0,0,0"/>
            </Grid>

            <TextBlock x:Name="StatusText"
                       FontFamily="Segoe UI"
                       FontSize="9"
                       Foreground="#66FFFFFF"
                       Margin="0,8,0,0"
                       Text="En attente de F1 25…"/>
        </StackPanel>
    </Border>
</Window>
