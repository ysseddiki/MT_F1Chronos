<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT_F1Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="8"
            BorderThickness="1"
            Opacity="0.96">
        <Border.Background>
            <SolidColorBrush Color="#F00D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- F1 accent bar -->
            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <StackPanel Grid.Column="1" Margin="12,10,10,10">
                <Grid Margin="0,0,0,8" MouseLeftButtonDown="OnHeaderDrag">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TrackText"
                               Grid.Column="0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FFC5CAD3"
                               VerticalAlignment="Center"/>
                    <Button x:Name="MenuButton"
                            Grid.Column="1"
                            Content="☰"
                            Width="28"
                            Height="24"
                            FontSize="14"
                            Padding="0"
                            Margin="8,0,0,0"
                            Background="#FF161B22"
                            Foreground="#FFC5CAD3"
                            BorderBrush="#33FFFFFF"
                            Cursor="Hand"
                            Click="OnMenuButtonClick">
                        <Button.ContextMenu>
                            <ContextMenu Background="White"
                                         Foreground="Black"
                                         BorderBrush="#FFCCCCCC"
                                         BorderThickness="1"
                                         Padding="2">
                                <ContextMenu.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="Black"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFE8E8E8"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>

                                    <Style TargetType="{x:Type ContextMenu}">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                    <Style TargetType="{x:Type MenuItem}">
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="Margin" Value="2,1"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#FFE8E8E8"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#FF999999"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type Separator}">
                                        <Setter Property="Margin" Value="6,6"/>
                                        <Setter Property="Background" Value="#FFDDDDDD"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                                <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                                <MenuItem Header="Exporter les scores">
                                    <MenuItem Header="CSV" Click="OnExportCsvClick"/>
                                    <MenuItem Header="JSON" Click="OnExportJsonClick"/>
                                    <MenuItem Header="HTML" Click="OnExportHtmlClick"/>
                                </MenuItem>
                                <MenuItem x:Name="ResetScoresMenu"
                                          Header="Réinitialiser les scores"
                                          Visibility="Collapsed">
                                    <MenuItem Header="Circuit affiché…" Click="OnResetCurrentTrackClick"/>
                                    <MenuItem Header="Tous les circuits…" Click="OnResetAllClick"/>
                                </MenuItem>
                                <MenuItem Header="Classement">
                                    <MenuItem x:Name="Top5MenuItem" Header="TOP 5" IsCheckable="True" Click="OnTop5Click"/>
                                    <MenuItem x:Name="Top10MenuItem" Header="TOP 10" IsCheckable="True" Click="OnTop10Click"/>
                                </MenuItem>
                                <MenuItem Header="Taille de l'overlay">
                                    <MenuItem Header="Petit" Click="OnSizeSmallClick"/>
                                    <MenuItem Header="Moyen" Click="OnSizeMediumClick"/>
                                    <MenuItem Header="Grand" Click="OnSizeLargeClick"/>
                                </MenuItem>
                                <MenuItem Header="Opacité" StaysOpenOnClick="True">
                                    <MenuItem StaysOpenOnClick="True">
                                        <MenuItem.Header>
                                            <DockPanel Width="180" Margin="4,2">
                                                <TextBlock x:Name="OpacityValueText"
                                                           DockPanel.Dock="Right"
                                                           Width="40"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Right"
                                                           Foreground="Black"
                                                           Text="96%"/>
                                                <Slider x:Name="OpacitySlider"
                                                        Minimum="60"
                                                        Maximum="100"
                                                        Value="96"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        VerticalAlignment="Center"
                                                        ValueChanged="OnOpacitySliderChanged"/>
                                            </DockPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </MenuItem>
                                <MenuItem Header="Format UDP">
                                    <MenuItem Header="2025 (F1 25)" Click="OnFormat2025Click"/>
                                    <MenuItem Header="2026" Click="OnFormat2026Click"/>
                                </MenuItem>
                                <MenuItem Header="Debug UDP" Click="OnDebugClick"/>
                                <Separator/>
                                <MenuItem Header="Quitter" Click="OnQuitClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <TextBlock x:Name="LeaderboardTitleText"
                           Text="TOP 5"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#FFE10600"
                           Margin="0,0,0,6"/>

                <StackPanel x:Name="TopFivePanel" Margin="0,0,0,10"/>

                <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,0,0,10"/>

                <TextBlock Text="TOUR EN COURS"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#FF5E8BFF"
                           Margin="0,0,0,6"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PlayerNameText"
                               Grid.Column="0"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFFFF"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="CurrentLapText"
                               Grid.Column="1"
                               FontFamily="Consolas"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FFFFFFFF"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border x:Name="StatusBorder"
                        Margin="0,2,0,0"
                        Padding="8,5"
                        Background="#B2161B22"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="StatusDot"
                                 Grid.Column="0"
                                 Width="8"
                                 Height="8"
                                 Fill="#FFEA9A00"
                                 VerticalAlignment="Center"/>

                        <TextBlock x:Name="StatusText"
                                   Grid.Column="1"
                                   Margin="8,0,0,0"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#FFC5CAD3"
                                   VerticalAlignment="Center"
                                   Text="En attente de F1…"/>

                        <TextBlock x:Name="StatusIconText"
                                   Grid.Column="2"
                                   Margin="10,0,0,0"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#FFEA9A00"
                                   VerticalAlignment="Center"
                                   Text="▱"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
