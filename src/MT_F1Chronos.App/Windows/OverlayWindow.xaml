<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT_F1Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="4"
            BorderThickness="1"
            Padding="10,8"
            Opacity="0.92">
        <Border.Background>
            <SolidColorBrush Color="#CC0A0A0F"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#55FFFFFF"/>
        </Border.BorderBrush>
        <StackPanel>
            <Grid Margin="0,0,0,6" MouseLeftButtonDown="OnHeaderDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TrackText"
                           Grid.Column="0"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#FFB0B8C8"
                           VerticalAlignment="Center"/>
                <Button x:Name="MenuButton"
                        Grid.Column="1"
                        Content="☰"
                        Width="26"
                        Height="22"
                        FontSize="13"
                        Padding="0"
                        Margin="6,0,0,0"
                        Background="#FF1A1A24"
                        Foreground="White"
                        BorderBrush="#44FFFFFF"
                        Cursor="Hand"
                        Click="OnMenuButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu Background="#FF1A1A24" Foreground="White" BorderBrush="#44FFFFFF">
                            <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                            <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                            <MenuItem Header="Taille de l'overlay">
                                <MenuItem Header="Petit" Click="OnSizeSmallClick"/>
                                <MenuItem Header="Moyen" Click="OnSizeMediumClick"/>
                                <MenuItem Header="Grand" Click="OnSizeLargeClick"/>
                            </MenuItem>
                            <MenuItem Header="Format UDP">
                                <MenuItem Header="2025 (F1 25)" Click="OnFormat2025Click"/>
                                <MenuItem Header="2026" Click="OnFormat2026Click"/>
                            </MenuItem>
                            <MenuItem Header="Diagnostic UDP" Click="OnDiagnosticsClick"/>
                            <Separator/>
                            <MenuItem Header="Quitter" Click="OnQuitClick"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>

            <TextBlock Text="TOP 5"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#FFE10600"
                       Margin="0,0,0,4"/>

            <StackPanel x:Name="TopFivePanel" Margin="0,0,0,8"/>

            <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,8"/>

            <TextBlock Text="TOUR EN COURS"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#FF5E8BFF"
                       Margin="0,0,0,4"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PlayerNameText"
                           Grid.Column="0"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="CurrentLapText"
                           Grid.Column="1"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FF5E8BFF"
                           Margin="12,0,0,0"/>
            </Grid>

            <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,8"/>

            <TextBlock Text="MEILLEUR TOUR"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="Bold"
                       Foreground="#FF00D2BE"
                       Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BestLabelText"
                           Grid.Column="0"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="CurrentBestText"
                           Grid.Column="1"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FFFFD700"
                           Margin="12,0,0,0"/>
            </Grid>

            <TextBlock x:Name="StatusText"
                       FontFamily="Segoe UI"
                       FontSize="9"
                       Foreground="#66FFFFFF"
                       Margin="0,8,0,0"
                       Text="En attente de F1 26…"/>

            <TextBlock x:Name="DiagnosticsText"
                       FontFamily="Consolas"
                       FontSize="8"
                       Foreground="#55FFFFFF"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>
