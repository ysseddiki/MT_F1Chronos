<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="F1 Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="8"
            BorderThickness="1"
            Opacity="0.96">
        <Border.Background>
            <SolidColorBrush Color="#F00D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- F1 accent bar -->
            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <StackPanel Grid.Column="1" Margin="12,10,10,10">
                <Grid Margin="0,0,0,10" MouseLeftButtonDown="OnHeaderDrag">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TrackText"
                               Grid.Column="0"
                               FontFamily="Segoe UI Semibold, Segoe UI"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#FFC5CAD3"
                               VerticalAlignment="Center"/>
                    <Button x:Name="MenuButton"
                            Grid.Column="1"
                            Content="☰"
                            Width="28"
                            Height="24"
                            FontSize="14"
                            Padding="0"
                            Margin="8,0,0,0"
                            Background="#FF161B22"
                            Foreground="#FFC5CAD3"
                            BorderBrush="#33FFFFFF"
                            Cursor="Hand"
                            Click="OnMenuButtonClick">
                        <Button.ContextMenu>
                            <ContextMenu Background="#FF161B22"
                                         Foreground="#FFFFFFFF"
                                         BorderBrush="#33FFFFFF"
                                         BorderThickness="1"
                                         Padding="4">
                                <ContextMenu.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF161B22"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF161B22"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF161B22"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFFFFFFF"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF1C222B"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>

                                    <Style TargetType="{x:Type ContextMenu}">
                                        <Setter Property="Background" Value="#FF161B22"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                    <Style TargetType="{x:Type MenuItem}">
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="Margin" Value="2,1"/>
                                        <Setter Property="Background" Value="#FF161B22"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#FF1C222B"/>
                                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type Separator}">
                                        <Setter Property="Margin" Value="6,6"/>
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                                <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                                <MenuItem Header="Administration" Click="OnAdminClick"/>
                                <Separator/>
                                <MenuItem Header="Quitter" Click="OnQuitClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <!-- TOP = primary content -->
                <StackPanel x:Name="GlobalSection">
                    <TextBlock x:Name="LeaderboardTitleText"
                               Text="TOP 5 · GLOBAL"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,8"/>
                    <StackPanel x:Name="TopFivePanel" Margin="0,0,0,4"/>
                </StackPanel>

                <StackPanel x:Name="ContestSection" Visibility="Collapsed" Margin="0,0,0,4">
                    <Rectangle x:Name="ContestDivider"
                               Height="1"
                               Fill="#22FFFFFF"
                               Margin="0,6,0,10"/>
                    <TextBlock x:Name="ContestTitleText"
                               Text="TOP 10 · CONCOURS"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,8"/>
                    <StackPanel x:Name="ContestPanel"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,8,0,8"/>

                <!-- Secondary: player + live lap + telemetry square (bottom-right) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock x:Name="PlayerNameText"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#FFC5CAD3"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="CurrentLapText"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFFFF"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border x:Name="StatusSquare"
                            Grid.Column="1"
                            Width="8"
                            Height="8"
                            CornerRadius="1"
                            Background="#FFE10600"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,2"
                            ToolTip="Télémétrie"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
