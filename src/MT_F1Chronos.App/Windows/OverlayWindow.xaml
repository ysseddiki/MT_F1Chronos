<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT_F1Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="2"
            BorderThickness="1"
            Opacity="0.96">
        <Border.Background>
            <SolidColorBrush Color="#F00D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- F1 accent bar -->
            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="2,0,0,2"/>

            <StackPanel Grid.Column="1" Margin="12,10,10,10">
                <Grid Margin="0,0,0,8" MouseLeftButtonDown="OnHeaderDrag">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TrackText"
                               Grid.Column="0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FFC5CAD3"
                               VerticalAlignment="Center"/>
                    <Button x:Name="MenuButton"
                            Grid.Column="1"
                            Content="☰"
                            Width="28"
                            Height="24"
                            FontSize="14"
                            Padding="0"
                            Margin="8,0,0,0"
                            Background="#FF161B22"
                            Foreground="#FFC5CAD3"
                            BorderBrush="#33FFFFFF"
                            Cursor="Hand"
                            Click="OnMenuButtonClick">
                        <Button.ContextMenu>
                            <ContextMenu Background="#FF161B22"
                                         Foreground="#FFFFFFFF"
                                         BorderBrush="#33FFFFFF"
                                         BorderThickness="1"
                                         Padding="2">
                                <ContextMenu.Resources>
                                    <Style TargetType="{x:Type MenuItem}">
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="Margin" Value="2,1"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#FF0D1117"/>
                                                <Setter Property="BorderBrush" Value="#55E10600"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type Separator}">
                                        <Setter Property="Margin" Value="6,6"/>
                                        <Setter Property="Background" Value="#22FFFFFF"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                                <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                                <MenuItem Header="Taille de l'overlay">
                                    <MenuItem Header="Petit" Click="OnSizeSmallClick"/>
                                    <MenuItem Header="Moyen" Click="OnSizeMediumClick"/>
                                    <MenuItem Header="Grand" Click="OnSizeLargeClick"/>
                                </MenuItem>
                                <MenuItem Header="Format UDP">
                                    <MenuItem Header="2025 (F1 25)" Click="OnFormat2025Click"/>
                                    <MenuItem Header="2026" Click="OnFormat2026Click"/>
                                </MenuItem>
                                <MenuItem Header="Debug UDP" Click="OnDebugClick"/>
                                <Separator/>
                                <MenuItem Header="Quitter" Click="OnQuitClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>

                <TextBlock Text="TOP 5"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#FFE10600"
                           Margin="0,0,0,6"/>

                <StackPanel x:Name="TopFivePanel" Margin="0,0,0,10"/>

                <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,0,0,10"/>

                <TextBlock Text="TOUR EN COURS"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#FF5E8BFF"
                           Margin="0,0,0,6"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PlayerNameText"
                               Grid.Column="0"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFFFF"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="CurrentLapText"
                               Grid.Column="1"
                               FontFamily="Consolas"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FF5E8BFF"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>

                <TextBlock x:Name="StatusText"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Foreground="#66FFFFFF"
                           Text="En attente de F1…"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
