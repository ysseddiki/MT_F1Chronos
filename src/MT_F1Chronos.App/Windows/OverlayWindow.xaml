<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="F1 Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="12"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F00A0A10"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#33FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Soft white edge (mockup) -->
            <Border Grid.Column="0"
                    Background="#FFFFFFFF"
                    CornerRadius="12,0,0,12"/>

            <StackPanel Grid.Column="1" Margin="12,14,12,10">
                <!-- Header: circuit on its own row; pseudo + chrono share the next row -->
                <StackPanel Margin="0,0,0,8" MouseLeftButtonDown="OnHeaderDrag">
                    <TextBlock x:Name="TrackText"
                               FontFamily="Bahnschrift, Segoe UI"
                               FontSize="28"
                               FontWeight="Bold"
                               FontStyle="Italic"
                               FontStretch="Condensed"
                               Foreground="#FFFFFFFF"
                               TextTrimming="CharacterEllipsis"/>
                    <Grid Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PlayerNameText"
                                   Grid.Column="0"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FFA8A8B3"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <!-- Vector chrono / stopwatch pictogram -->
                            <Canvas Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse Width="12" Height="12" Canvas.Left="1" Canvas.Top="2"
                                         Stroke="#FFFFFFFF" StrokeThickness="1.4" Fill="Transparent"/>
                                <Rectangle Width="3" Height="2" Canvas.Left="5.5" Canvas.Top="0"
                                           RadiusX="0.5" RadiusY="0.5" Fill="#FFFFFFFF"/>
                                <Line X1="7" Y1="8" X2="7" Y2="5"
                                      Stroke="#FFFFFFFF" StrokeThickness="1.4" StrokeStartLineCap="Round"/>
                                <Line X1="7" Y1="8" X2="9.5" Y2="8"
                                      Stroke="#FFFFFFFF" StrokeThickness="1.4" StrokeEndLineCap="Round"/>
                            </Canvas>
                            <TextBlock x:Name="CurrentLapText"
                                       FontFamily="Consolas"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFFFF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- TOP Global cartouche -->
                <Border x:Name="GlobalSection"
                        Background="#FF14141C"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="2"
                                          Direction="270"
                                          Color="#000000"
                                          Opacity="0.35"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#FFE10600"
                                CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1">
                            <Border Background="#FF1E1E28" Padding="10,10">
                                <TextBlock x:Name="LeaderboardTitleText"
                                           Text="TOP 5 · GLOBAL"
                                           FontFamily="Bahnschrift, Segoe UI"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           FontStretch="Condensed"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Height="1" Fill="#33FFFFFF"/>
                            <StackPanel x:Name="TopFivePanel" Margin="10,10,10,10"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TOP Concours cartouche -->
                <Border x:Name="ContestSection"
                        Background="#FF14141C"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,8,0,0"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="2"
                                          Direction="270"
                                          Color="#000000"
                                          Opacity="0.35"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#FF5E8BFF"
                                CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1">
                            <Border Background="#FF1E1E28" Padding="10,10">
                                <TextBlock x:Name="ContestTitleText"
                                           Text="TOP 5 · CONCOURS"
                                           FontFamily="Bahnschrift, Segoe UI"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           FontStretch="Condensed"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Height="1" Fill="#33FFFFFF"/>
                            <StackPanel x:Name="ContestPanel" Margin="10,10,10,10"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Footer: best-per-player toggle · status LED · vector burger -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Best-per-player slide toggle + full label -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                ToolTip="Basculer tous les chronos / meilleur par joueur"
                                MouseLeftButtonUp="OnBestPerPlayerToggleClick">
                        <Border x:Name="BestPerPlayerToggle"
                                Width="44"
                                Height="22"
                                CornerRadius="11"
                                Background="#FF252530"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                            <Canvas>
                                <Ellipse x:Name="BestPerPlayerKnob"
                                         Width="16"
                                         Height="16"
                                         Canvas.Left="3"
                                         Canvas.Top="2"
                                         Fill="#FFFFFFFF"
                                         IsHitTestVisible="False"/>
                            </Canvas>
                        </Border>
                        <TextBlock x:Name="BestPerPlayerLabel"
                                   Text="Tous les chronos"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#FFA8A8B3"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   IsHitTestVisible="False"/>
                    </StackPanel>

                    <Grid x:Name="StatusBadge"
                          Grid.Column="2"
                          Width="26"
                          Height="26"
                          ClipToBounds="False"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          ToolTip="Télémétrie">
                        <Ellipse x:Name="StatusGlow"
                                 Width="16"
                                 Height="16"
                                 Fill="#FF00D26A"
                                 Opacity="0.7"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <BlurEffect x:Name="StatusGlowBlur"
                                            Radius="8"
                                            KernelType="Gaussian"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="StatusCore"
                                 Width="8"
                                 Height="8"
                                 Fill="#FF00D26A"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="False"/>
                    </Grid>

                    <Button x:Name="MenuButton"
                            Grid.Column="3"
                            Width="28"
                            Height="24"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="OnMenuButtonClick"
                            ToolTip="Menu">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        Padding="4,3">
                                    <!-- Vector burger -->
                                    <Canvas Width="16" Height="12">
                                        <Rectangle Width="16" Height="2" Canvas.Top="0" RadiusX="1" RadiusY="1" Fill="#FFFFFFFF"/>
                                        <Rectangle Width="16" Height="2" Canvas.Top="5" RadiusX="1" RadiusY="1" Fill="#FFFFFFFF"/>
                                        <Rectangle Width="16" Height="2" Canvas.Top="10" RadiusX="1" RadiusY="1" Fill="#FFFFFFFF"/>
                                    </Canvas>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu Background="#FF1A1A24"
                                         Foreground="#FFFFFFFF"
                                         BorderBrush="#33FFFFFF"
                                         BorderThickness="1"
                                         Padding="4">
                                <ContextMenu.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFFFFFFF"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF252530"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>

                                    <Style TargetType="{x:Type ContextMenu}">
                                        <Setter Property="Background" Value="#FF1A1A24"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                    <Style TargetType="{x:Type MenuItem}">
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="Margin" Value="2,1"/>
                                        <Setter Property="Background" Value="#FF1A1A24"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#FF252530"/>
                                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type Separator}">
                                        <Setter Property="Margin" Value="6,6"/>
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                                <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                                <MenuItem Header="Administration" Click="OnAdminClick"/>
                                <Separator/>
                                <MenuItem Header="Quitter" Click="OnQuitClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
