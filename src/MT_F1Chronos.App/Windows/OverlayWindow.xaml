<Window x:Class="MT_F1Chronos.App.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="F1 Chronos"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Focusable="True"
        ShowActivated="True">
    <Border x:Name="RootBorder"
            CornerRadius="12"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F00A0A10"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#33FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Soft white edge (mockup) -->
            <Border Grid.Column="0"
                    Background="#FFFFFFFF"
                    CornerRadius="12,0,0,12"/>

            <StackPanel Grid.Column="1" Margin="12,14,12,10">
                <!-- Header: circuit on its own row; pseudo + chrono share the next row -->
                <StackPanel Margin="0,0,0,8" MouseLeftButtonDown="OnHeaderDrag">
                    <TextBlock x:Name="TrackText"
                               FontFamily="Bahnschrift, Segoe UI"
                               FontSize="28"
                               FontWeight="Bold"
                               FontStyle="Italic"
                               FontStretch="Condensed"
                               Foreground="#FFFFFFFF"
                               TextTrimming="CharacterEllipsis"/>
                    <Grid Margin="0,3,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PlayerNameText"
                                   Grid.Column="0"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FFA8A8B3"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock x:Name="CurrentLapText"
                                   Grid.Column="1"
                                   FontFamily="Consolas"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFFFF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- TOP Global cartouche -->
                <Border x:Name="GlobalSection"
                        Background="#FF14141C"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#FFE10600"
                                CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1">
                            <Border Background="#FF1E1E28" Padding="10,10">
                                <TextBlock x:Name="LeaderboardTitleText"
                                           Text="TOP 5 · GLOBAL"
                                           FontFamily="Bahnschrift, Segoe UI"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           FontStretch="Condensed"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Height="1" Fill="#33FFFFFF"/>
                            <StackPanel x:Name="TopFivePanel" Margin="10,10,10,10"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TOP Concours cartouche -->
                <Border x:Name="ContestSection"
                        Background="#FF14141C"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,8,0,0"
                        Visibility="Collapsed"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#FF5E8BFF"
                                CornerRadius="4,0,0,4"/>
                        <StackPanel Grid.Column="1">
                            <Border Background="#FF1E1E28" Padding="10,10">
                                <TextBlock x:Name="ContestTitleText"
                                           Text="TOP 5 · CONCOURS"
                                           FontFamily="Bahnschrift, Segoe UI"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           FontStretch="Condensed"
                                           Foreground="#FFFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Height="1" Fill="#33FFFFFF"/>
                            <StackPanel x:Name="ContestPanel" Margin="10,10,10,10"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Footer: soft glowing status point + burger (no hard ring) -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="StatusBadge"
                          Grid.Column="1"
                          Width="22"
                          Height="22"
                          ClipToBounds="False"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          ToolTip="Télémétrie">
                        <!-- Soft halo only — no stroked ring -->
                        <Ellipse x:Name="StatusGlow"
                                 Width="14"
                                 Height="14"
                                 Fill="#FF00D26A"
                                 Opacity="0.7"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <BlurEffect x:Name="StatusGlowBlur"
                                            Radius="8"
                                            KernelType="Gaussian"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse x:Name="StatusCore"
                                 Width="7"
                                 Height="7"
                                 Fill="#FF00D26A"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="False"/>
                    </Grid>

                    <Button x:Name="MenuButton"
                            Grid.Column="2"
                            Content="☰"
                            Width="28"
                            Height="24"
                            FontSize="14"
                            Padding="0"
                            Background="Transparent"
                            Foreground="#FFFFFFFF"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Click="OnMenuButtonClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu Background="#FF1A1A24"
                                         Foreground="#FFFFFFFF"
                                         BorderBrush="#33FFFFFF"
                                         BorderThickness="1"
                                         Padding="4">
                                <ContextMenu.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF1A1A24"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFFFFFFF"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF252530"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>

                                    <Style TargetType="{x:Type ContextMenu}">
                                        <Setter Property="Background" Value="#FF1A1A24"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Style>
                                    <Style TargetType="{x:Type MenuItem}">
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="Margin" Value="2,1"/>
                                        <Setter Property="Background" Value="#FF1A1A24"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#FF252530"/>
                                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="{x:Type Separator}">
                                        <Setter Property="Margin" Value="6,6"/>
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>

                                <MenuItem Header="Changer le nom du joueur" Click="OnRenameClick"/>
                                <MenuItem Header="Scores par circuit" Click="OnScoresClick"/>
                                <MenuItem Header="Administration" Click="OnAdminClick"/>
                                <Separator/>
                                <MenuItem Header="Quitter" Click="OnQuitClick"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
