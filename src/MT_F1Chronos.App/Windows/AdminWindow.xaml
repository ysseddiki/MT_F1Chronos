<Window x:Class="MT_F1Chronos.App.Windows.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Administration — F1 Chronos"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="420"
        SizeToContent="Height"
        ShowInTaskbar="False">
    <Border CornerRadius="8"
            BorderThickness="1"
            Opacity="0.98">
        <Border.Background>
            <SolidColorBrush Color="#F50D1117"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#22FFFFFF"/>
        </Border.BorderBrush>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFE10600"
                    CornerRadius="8,0,0,8"/>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="640">
                <StackPanel Margin="16,16,16,16">
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF161B22"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF1C222B"/>
                                    <Setter Property="BorderBrush" Value="#88E10600"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF0D1117"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Header -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ADMINISTRATION"
                                   FontFamily="Segoe UI"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="✕"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Margin="0"
                                HorizontalContentAlignment="Center"
                                FontSize="14"
                                Click="OnCloseClick"/>
                    </Grid>

                    <!-- Scores -->
                    <TextBlock Text="SCORES GLOBAUX"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,8"/>
                    <Button Content="Voir les scores par circuit"
                            Click="OnScoresClick"/>
                    <Button Content="Réinitialiser le circuit affiché…"
                            Click="OnResetCurrentTrackClick"/>
                    <Button Content="Réinitialiser tous les scores…"
                            Click="OnResetAllClick"
                            Foreground="#FFFF8A80"
                            BorderBrush="#66E10600"/>

                    <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,8,0,12"/>

                    <!-- Export -->
                    <TextBlock Text="EXPORTATION"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="CSV"
                                Margin="0,0,4,0"
                                HorizontalContentAlignment="Center"
                                Click="OnExportCsvClick"/>
                        <Button Grid.Column="1"
                                Content="JSON"
                                Margin="0,0,4,0"
                                HorizontalContentAlignment="Center"
                                Click="OnExportJsonClick"/>
                        <Button Grid.Column="2"
                                Content="HTML"
                                Margin="0"
                                HorizontalContentAlignment="Center"
                                Click="OnExportHtmlClick"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,8,0,12"/>

                    <!-- Affichage -->
                    <TextBlock Text="AFFICHAGE OVERLAY"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Classement"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Foreground="#FFC5CAD3"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Top5Button"
                                Grid.Column="0"
                                Content="TOP 5"
                                Margin="0,0,4,0"
                                HorizontalContentAlignment="Center"
                                Click="OnTop5Click"/>
                        <Button x:Name="Top10Button"
                                Grid.Column="1"
                                Content="TOP 10"
                                Margin="0"
                                HorizontalContentAlignment="Center"
                                Click="OnTop10Click"/>
                    </Grid>
                    <TextBlock Text="Taille"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Foreground="#FFC5CAD3"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SizeSmallButton"
                                Grid.Column="0"
                                Content="Petit"
                                Margin="0,0,4,0"
                                HorizontalContentAlignment="Center"
                                Click="OnSizeSmallClick"/>
                        <Button x:Name="SizeMediumButton"
                                Grid.Column="1"
                                Content="Moyen"
                                Margin="0,0,4,0"
                                HorizontalContentAlignment="Center"
                                Click="OnSizeMediumClick"/>
                        <Button x:Name="SizeLargeButton"
                                Grid.Column="2"
                                Content="Grand"
                                Margin="0"
                                HorizontalContentAlignment="Center"
                                Click="OnSizeLargeClick"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,8,0,12"/>

                    <!-- Concours placeholder -->
                    <TextBlock Text="CONCOURS"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,6"/>
                    <Border Background="#B2161B22"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock Text="Bientôt : créer, démarrer, arrêter et exporter des tableaux de scores parallèles pour les concours — sans toucher au classement global."
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#FFC5CAD3"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Debug -->
                    <TextBlock Text="DIAGNOSTIC"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#FFE10600"
                               Margin="0,0,0,8"/>
                    <Button Content="Ouvrir Debug UDP"
                            Click="OnDebugClick"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
